LW_SERVER=example.com
LW_SERVER_USER=root
LW_SERVER_PORT=22
LW_SERVER_DIR=/opt/lw
LW_IMAGE_PREFIX=learnword

# Optional. If empty, scripts generate a timestamp tag.
LW_IMAGE_TAG=

# Optional. If set, this file is uploaded to the server as ${LW_SERVER_DIR}/.env.
# Use deploy/env/prod.env.example as a template and keep real secrets out of git.
LW_REMOTE_ENV_FILE=
