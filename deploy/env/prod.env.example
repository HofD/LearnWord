LW_IMAGE_PREFIX=learnword
LW_IMAGE_TAG=replace-with-deployed-tag
LW_PLATFORM=linux/amd64

LW_DB_HOST=192.168.0.6
LW_DB_PORT=5432
LW_DB_NAME=lwdb
LW_DB_USER=replace-me
LW_DB_PASSWORD=replace-me

LW_GATEWAY_PORT=5000
LW_IDENTITYSERVICE_PORT=5001
LW_IDENTITY_PORT=5002
LW_WEBAPI_PORT=5003
LW_WEBAPP_PORT=8080
LW_BIND_IP=127.0.0.1

LW_JWT_ISSUER=LearnWordIdentity
LW_JWT_AUDIENCE=learnword.online
LW_JWT_KEY=replace-with-long-random-secret
LW_JWT_EXPIRY_MINUTES=5
LW_REFRESH_TOKEN_TTL=7

LW_SMTP_HOST=mail.learnword.online
LW_SMTP_PORT=465
LW_SMTP_USE_SSL=true
LW_SMTP_FROM_NAME=Learn Word Online
LW_SMTP_FROM_EMAIL=register@learnword.online
LW_SMTP_USERNAME=register@learnword.online
LW_SMTP_PASSWORD=replace-me
LW_EMAIL_CONFIRMATION_URL=https://learnword.online/confirm
