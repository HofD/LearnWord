LW_IMAGE_PREFIX=learnword
LW_IMAGE_TAG=local
# Standard image pull mode for deploy/local-up scripts:
# missing = pull only images that are not present locally
# never = never pull standard images
# always = force-refresh standard images before compose/build
LW_STANDARD_IMAGE_PULL=missing

LW_DB_NAME=lwdb
LW_DB_USER=lwuser
LW_DB_PASSWORD=lwpassword
LW_DB_PORT=5432

LW_GATEWAY_PORT=5100
LW_IDENTITYSERVICE_PORT=5001
LW_IDENTITY_PORT=5002
LW_WEBAPI_PORT=5003
LW_WEBAPP_PORT=8088
LW_MAILPIT_UI_PORT=8025

LW_JWT_ISSUER=LearnWordIdentity
LW_JWT_AUDIENCE=learnword.local
LW_JWT_KEY=local-development-jwt-key-change-me-32-chars
LW_JWT_EXPIRY_MINUTES=60
LW_REFRESH_TOKEN_TTL=7

LW_AI_PROVIDER=Fake
LW_AI_MAX_SOURCE_TEXT_LENGTH=4000
LW_AI_MAX_CARDS=10
LW_AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
LW_AI_OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
LW_AI_OPENROUTER_API_KEY=
LW_AI_OPENROUTER_TIMEOUT_SECONDS=60
