{
  "ConnectionStrings": {
    "LwConnection": "Host=__DB_HOST__;Port=5432;Database=__DB_NAME__;Username=__DB_USER__;Password=change-me"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "LearnWord.com",
    "Audience": "LearnWord.com",
    "Key": "__JWT_SIGNING_KEY_FROM_ENV__",
    "ExpiryInMinutes": 5
  },
  "LwServicesRoutes": {
    "CollectionsRoute": "http://learnword.webapi:8080/collections",
    "CardsRoute": "http://learnword.webapi:8080/cards",
    "WordsRoute": "http://learnword.webapi:8080/cards"
  }
}
